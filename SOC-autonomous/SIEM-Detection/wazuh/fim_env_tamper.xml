<!--
  Wazuh Rule: FIM — Sensitive Secrets File Modification
  ======================================================
  Detects modification of .env, credentials, and secrets files
  via Wazuh FIM (syscheck) realtime monitoring.

  MITRE ATT&CK : T1565.001 — Stored Data Manipulation
                 T1552.001 — Credentials In Files
  Severity     : HIGH (level 12)
  Source       : Wazuh syscheck rule 550 (integrity checksum changed)

  Deploy       : /var/ossec/rules/local_rules.xml
  Reload       : /var/ossec/bin/wazuh-control restart
-->

<group name="syscheck,secrets,credential_access,fim_tamper">

  <!-- Base rule: any .env or secrets file modified -->
  <rule id="100100" level="12">
    <if_group>syscheck</if_group>
    <field name="syscheck.path">\.env$|\.env\.|secrets\.|credentials\.|\.pem$|\.key$|\.pfx$</field>
    <description>Sensitive secrets file modified: $(syscheck.path)</description>
    <mitre>
      <id>T1565.001</id>
      <id>T1552.001</id>
    </mitre>
    <group>credential_access,impact,pci_dss_11.5,hipaa_164.312.c.1</group>
  </rule>

  <!-- Escalated: secrets file AND permissions changed (attacker hiding tracks) -->
  <rule id="100101" level="14">
    <if_sid>100100</if_sid>
    <field name="syscheck.changed_attributes">perm</field>
    <description>Secrets file modified AND permissions changed — possible attacker covering tracks: $(syscheck.path)</description>
    <mitre>
      <id>T1565.001</id>
      <id>T1222.002</id>
    </mitre>
  </rule>

  <!-- Secrets file deleted — possible exfil + cleanup -->
  <rule id="100102" level="13">
    <if_group>syscheck</if_group>
    <field name="syscheck.path">\.env$|credentials\.|\.pem$|\.key$</field>
    <field name="syscheck.event">deleted</field>
    <description>Secrets file deleted — possible exfiltration and cleanup: $(syscheck.path)</description>
    <mitre>
      <id>T1070.004</id>
      <id>T1552.001</id>
    </mitre>
  </rule>

  <!-- SSH authorized_keys modification — persistence via key injection -->
  <rule id="100103" level="13">
    <if_group>syscheck</if_group>
    <field name="syscheck.path">authorized_keys|\.ssh/</field>
    <description>SSH authorized_keys modified — possible persistence key injection: $(syscheck.path)</description>
    <mitre>
      <id>T1098.004</id>
    </mitre>
  </rule>

  <!-- Sudoers modification — privilege escalation via sudo rules -->
  <rule id="100104" level="14">
    <if_group>syscheck</if_group>
    <field name="syscheck.path">sudoers|/etc/sudoers\.d/</field>
    <description>sudoers file modified — privilege escalation via sudo rule: $(syscheck.path)</description>
    <mitre>
      <id>T1548.003</id>
    </mitre>
  </rule>

</group>
