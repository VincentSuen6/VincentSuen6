# Copy this to .env and fill in your keys — never commit .env

# ── Anthropic (Claude AI Analyst) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── NVD API (free — nvd.nist.gov/developers) ──────────────────────────────────
NVD_API_KEY=

# ── GitHub Audit Ledger ────────────────────────────────────────────────────────
# github.com/settings/tokens → repo scope
GITHUB_TOKEN=ghp_...
GITHUB_REPO=VincentSuen6/vuln-intel-agent
GITHUB_BRANCH=main

# ── Security Telemetry — Wazuh EDR ────────────────────────────────────────────
WAZUH_ALERT_LOG=/var/ossec/logs/alerts/alerts.json
MIN_ALERT_LEVEL=7
BRIDGE_POLL_INTERVAL=5

# ── Security Telemetry — Elastic SIEM ─────────────────────────────────────────
ELASTIC_URL=http://localhost:9200
ELASTIC_USER=elastic
ELASTIC_PASS=
ELASTIC_INDEX=winlogbeat-*,filebeat-*
ELASTIC_POLL_INTERVAL=30

# ── Security Telemetry — Docker Containers ─────────────────────────────────────
DOCKER_CONTAINERS=nginx,webapp,postgres   # csv of container names to monitor

# ── Splunk SIEM — HEC ─────────────────────────────────────────────────────────
# Settings → Data Inputs → HTTP Event Collector → New Token
SPLUNK_HOST=localhost
SPLUNK_HEC_PORT=8088
SPLUNK_HEC_TOKEN=
SPLUNK_INDEX=security
SPLUNK_SSL=false

# ── Threat Intel Feeds — Data Enrichment Engine ────────────────────────────────
# AbuseIPDB  — free at abuseipdb.com/account/api
ABUSEIPDB_KEY=

# VirusTotal — free at virustotal.com/gui/user/apikey
VIRUSTOTAL_KEY=

# OTX AlienVault — free at otx.alienvault.com/api
OTX_KEY=

# Shodan — free at account.shodan.io (limited to host lookup)
SHODAN_KEY=

# MISP — self-hosted; leave blank to skip
MISP_URL=http://localhost
MISP_KEY=

# ── Log Orchestrator ────────────────────────────────────────────────────────────
ENRICH_ENABLED=true
SPLUNK_ENABLED=true
CVE_AUTO_TRIGGER=true        # auto-run CVE pipeline when alert mentions a CVE

# ── Active Response Agent ───────────────────────────────────────────────────────
POLL_INTERVAL=60
# DRY_RUN=false              # uncomment to actually execute remediation commands
