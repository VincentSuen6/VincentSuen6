| Comment =====================================================================
| Splunk SPL: FIM — Secrets File Modification Detection
| ======================================================
| Detects Wazuh FIM alerts for .env, credentials, SSH keys, and sudoers.
| MITRE: T1565.001 (Stored Data Manipulation), T1552.001 (Credentials In Files)
| Index: wazuh-alerts | Recommended schedule: real-time alert
| ============================================================================

index=wazuh sourcetype="wazuh:json"
    rule.id=550 OR rule.id=553 OR rule.id=554
    syscheck.path IN ("*.env", "*.env.*", "*secrets*", "*credentials*", "*.pem", "*.key", "*.pfx",
                      "*authorized_keys*", "*sudoers*", "*shadow*", "*passwd")
| eval risk_level=case(
    match(syscheck.path, "\.env$|authorized_keys|sudoers|shadow"), "CRITICAL",
    match(syscheck.path, "credentials|secrets|\.key$|\.pem$"), "HIGH",
    true(), "MEDIUM"
  )
| eval changed_attrs=mvjoin(syscheck.changed_attributes, ", ")
| eval size_delta=syscheck.size_after - syscheck.size_before
| table _time, agent.name, syscheck.path, syscheck.event, changed_attrs,
        syscheck.size_before, syscheck.size_after, size_delta,
        syscheck.md5_before, syscheck.md5_after, rule.level, risk_level
| sort -risk_level, -_time
| rename agent.name AS "Agent", syscheck.path AS "Modified File",
         syscheck.event AS "Event", changed_attrs AS "Changed Attributes",
         size_delta AS "Size Delta (bytes)", rule.level AS "Wazuh Level",
         risk_level AS "Risk"
