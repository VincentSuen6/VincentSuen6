  {
    "name": "Brute Force: Password Spray — Multiple Users from Single IP",
    "description": "Detects password spraying: one source IP targeting 5+ distinct usernames with auth failures. Indicates a spray attack attempting to avoid per-user lockouts. MITRE T1110.003.",
    "rule_id": "soc-bf-003",
    "enabled": true,
    "risk_score": 73,
    "severity": "high",
    "type": "threshold",
    "language": "kuery",
    "query": "event.category:\"authentication\" and event.outcome:\"failure\"",
    "index": ["auditbeat-*", "filebeat-*", "winlogbeat-*", "wazuh-alerts-*", "logs-*"],
    "threshold": {
      "field": ["source.ip"],
      "value": 5,
      "cardinality": [
        {
          "field": "user.name",
          "value": 5
        }
      ]
    },
    "interval": "5m",
    "from": "now-6m",
    "max_signals": 100,
    "tags": ["SOC", "Credential Access", "Password Spray", "T1110.003"],
    "threat": [
      {
        "framework": "MITRE ATT&CK",
        "tactic": {
          "id": "TA0006",
          "name": "Credential Access",
          "reference": "https://attack.mitre.org/tactics/TA0006/"
        },
        "technique": [
          {
            "id": "T1110",
